# ⚠️ SECURITY CRITICAL - MUST BE SET PROPERLY

# Database Connection
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/coffee_pos"

# 🔒 SECURITY: JWT Secret (MUST BE 32+ CHARACTERS AND RANDOM)
# ❌ NEVER use default values!
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Example: JWT_SECRET="a7f3b9c2d1e8f4a5b6c7d8e9f0a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8"
JWT_SECRET="your-super-secret-jwt-key-min-32-characters-long-and-random"

# Frontend URL (for CORS Whitelisting - SECURITY)
# Only allow your own frontend domains
FRONTEND_URL="http://localhost:3000"

# Node Environment
NODE_ENV="development"

# Optional: Redis for Caching (improves performance significantly)
# REDIS_URL="redis://localhost:6379"

# AI/Gemini Configuration (Optional)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# App URL
APP_URL="http://localhost:3000"

# SMTP Configuration (Optional - for email notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_USER="support@yourdomain.com"
SMTP_PASS="your-app-password"
SMTP_FROM="support@yourdomain.com"

# ============================================
# SECURITY REMINDERS
# ============================================
# 1. JWT_SECRET: Generate a new strong secret and set it in production
# 2. FRONTEND_URL: Set to your actual domain in production
# 3. MONGODB_URI: Use secure connection string with auth
# 4. NODE_ENV: Set to "production" in production environment
# 5. Never commit .env with real secrets - only use .env.example as template
